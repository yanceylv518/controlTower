# Copy this file to a private path and fill in the values.
# Do not commit real tokens or MySQL passwords.

CT_AGENT_ID=agent-1
CT_INSTANCE_ID=new-api-1
CT_SERVER_URL=http://127.0.0.1:18081
CT_AGENT_TOKEN=local-agent-token

# Use a read-only MySQL account when possible.
# Example: user:password@tcp(127.0.0.1:3306)/newapi?parseTime=true&loc=UTC
CT_LOG_DSN=readonly_user:REPLACE_ME@tcp(127.0.0.1:3306)/newapi?parseTime=true&loc=UTC

CT_DATA_DIR=./data/agent
CT_LOG_POLL_INTERVAL_SECONDS=30
CT_LOG_BATCH_SIZE=1000
CT_LOG_QUERY_TIMEOUT_SECONDS=2
CT_REPORT_TIMEOUT_SECONDS=3
CT_MAX_LOCAL_BUFFER_EVENTS=5000
# full_debug is only needed if you also want the SERVER-side recent_errors rule;
# the agent-side DingTalk alert below works in every mode
CT_LOG_EVENT_MODE=aggregate_with_samples
CT_LOG_SAMPLE_LIMIT=50
CT_SLOW_LOG_THRESHOLD_SECONDS=10
CT_NEW_API_STATUS_URL=http://127.0.0.1:3000/api/status
CT_DOCKER_ENABLED=false
CT_CHANNEL_SNAPSHOT_ENABLED=true
CT_CHANNEL_SNAPSHOT_LIMIT=1000
CT_CHANNEL_SNAPSHOT_INTERVAL_SECONDS=600
CT_AGENT_RUN_ONCE=false




# Channel control is disabled by default. Keep this token on the Agent host only.
CT_NEW_API_CONTROL_ENABLED=false
CT_NEW_API_ADMIN_API_URL=http://127.0.0.1:3000
CT_NEW_API_ADMIN_USERNAME=REPLACE_WITH_NEW_API_ADMIN_USERNAME
CT_NEW_API_ADMIN_PASSWORD=REPLACE_WITH_NEW_API_ADMIN_PASSWORD
CT_NEW_API_ADMIN_ACCESS_TOKEN=REPLACE_WITH_NEW_API_ADMIN_ACCESS_TOKEN
CT_NEW_API_ADMIN_USER_ID=REPLACE_WITH_NEW_API_ADMIN_USER_ID

# Agent-side DingTalk error alert: any channel and any user with
# CT_ALERT_ERROR_THRESHOLD or more errors within the most recent
# CT_ALERT_ERROR_WINDOW requests triggers one group message per episode.
# With CT_DINGTALK_WEBHOOK_URL set, CT_SERVER_URL becomes optional
# (standalone alert-only mode).
CT_DINGTALK_WEBHOOK_URL=
CT_ALERT_ERROR_WINDOW=10
CT_ALERT_ERROR_THRESHOLD=3
CT_ALERT_WINDOW_MAX_AGE_MINUTES=60
CT_ALERT_REMIND_MINUTES=60
# Cache-miss alert: fires when the most recent CT_ALERT_NOCACHE_WINDOW
# successful requests with prompt_tokens > CT_ALERT_NOCACHE_MIN_PROMPT_TOKENS
# on one channel all report zero cached tokens. Any cache hit re-arms.
CT_ALERT_NOCACHE_ENABLED=true
CT_ALERT_NOCACHE_MIN_PROMPT_TOKENS=512
CT_ALERT_NOCACHE_WINDOW=10

# Nginx timed access log analytics. Leave CT_NGINX_ACCESS_LOG empty to disable.
# Missing/unreadable files only produce one warning and retry; standalone mode does not support this module.
CT_NGINX_ACCESS_LOG=
CT_NGINX_SLOW_RT_SECONDS=10

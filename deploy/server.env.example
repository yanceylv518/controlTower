CT_SERVER_LISTEN_ADDR=0.0.0.0:8080
CT_PUBLIC_BASE_URL=https://control-tower.example.com
CT_DATABASE_DRIVER=mysql
CT_DATABASE_DSN=controltower:REPLACE_WITH_CONTROL_TOWER_DATABASE_PASSWORD@tcp(control-tower-mysql:3306)/control_tower?parseTime=true&loc=UTC
CT_MIGRATION_PATH=server/migrations/001_init.sql
CT_AGGREGATION_INTERVAL_SECONDS=60
CT_NOTIFICATION_INTERVAL_SECONDS=30
CT_CHANNEL_SNAPSHOT_RETENTION_DAYS=30
CT_REDIS_ADDR=control-tower-redis:6379
CT_REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD
CT_AGENT_TOKEN=REPLACE_WITH_AGENT_BEARER_TOKEN
CT_DASHBOARD_TOKEN=REPLACE_WITH_DASHBOARD_BEARER_TOKEN
CT_ADMIN_USERNAME=
CT_ADMIN_INITIAL_PASSWORD=
CT_SESSION_TTL_HOURS=720
CT_AGENT_TOKEN_PEPPER=REPLACE_WITH_SERVER_SIDE_TOKEN_PEPPER

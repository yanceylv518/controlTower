# Published Server image. Pin a release tag; do not use latest in production.
CT_SERVER_IMAGE=ghcr.io/yanceylv518/controltower-server:v2.0.0-rc11

# MySQL 应用数据库名。
MYSQL_DATABASE=control_tower
# MySQL 应用账号。
MYSQL_USER=controltower
# MySQL 应用账号密码；部署前必须替换为强随机值。
MYSQL_PASSWORD=REPLACE_WITH_DATABASE_PASSWORD
# MySQL root 密码；仅用于容器初始化与健康检查。
MYSQL_ROOT_PASSWORD=REPLACE_WITH_ROOT_PASSWORD

# Server 监听地址；容器内保持 0.0.0.0:8080。
CT_SERVER_LISTEN_ADDR=0.0.0.0:8080
# 浏览器访问 Control Tower 的外部地址。
CT_PUBLIC_BASE_URL=http://localhost:8080
# 数据库驱动，当前固定为 mysql。
CT_DATABASE_DRIVER=mysql
# DSN 中的账号、密码必须与上方 MYSQL_USER/MYSQL_PASSWORD 一致。
CT_DATABASE_DSN=controltower:REPLACE_WITH_DATABASE_PASSWORD@tcp(mysql:3306)/control_tower?parseTime=true&loc=UTC
# 镜像内迁移入口；通常无需修改。
CT_MIGRATION_PATH=server/migrations/001_init.sql

# 兼容旧 Agent 的全局 Bearer Token；请使用强随机值。
CT_AGENT_TOKEN=REPLACE_WITH_AGENT_BEARER_TOKEN
# 兼容旧 Dashboard API 的 Bearer Token；请使用强随机值。
CT_DASHBOARD_TOKEN=REPLACE_WITH_DASHBOARD_BEARER_TOKEN
# 实例 Token 哈希使用的服务端 Pepper；部署后不要随意更换。
CT_AGENT_TOKEN_PEPPER=REPLACE_WITH_SERVER_SIDE_TOKEN_PEPPER

# 首次启动时创建的管理员用户名；已有用户后不会重复创建。
CT_ADMIN_USERNAME=admin
# 首次管理员初始密码；首次登录后立即修改。
CT_ADMIN_INITIAL_PASSWORD=REPLACE_WITH_ADMIN_PASSWORD
# 登录会话有效期（小时）。
CT_SESSION_TTL_HOURS=720

# 聚合任务间隔（秒）。
CT_AGGREGATION_INTERVAL_SECONDS=60
# 通知队列轮询间隔（秒）。
CT_NOTIFICATION_INTERVAL_SECONDS=30
# 单条通知最大尝试次数。
CT_NOTIFICATION_MAX_ATTEMPTS=8
# 渠道快照保留天数。
CT_CHANNEL_SNAPSHOT_RETENTION_DAYS=30
# 渠道命令过期时间（分钟）。
CT_COMMAND_EXPIRY_MINUTES=10
# 明细、样本与 1 分钟指标保留天数；0 表示不清理。
CT_RETENTION_DETAIL_DAYS=30
# 5 分钟指标保留天数；0 表示不清理。
CT_RETENTION_METRIC5M_DAYS=90
# Server 运行态指标保留天数；0 表示不清理。
CT_RETENTION_RUNTIME_DAYS=7
CT_RETENTION_HEALTH_HOURS=6
CT_OFFLINE_ALERT_SECONDS=120
CT_CPU_WARN_PERCENT=80
CT_CPU_CRIT_PERCENT=90
CT_MEMORY_WARN_PERCENT=80
CT_MEMORY_CRIT_PERCENT=90
CT_DISK_WARN_PERCENT=85
CT_DISK_CRIT_PERCENT=95
CT_ERROR_RATE_WARN_PERCENT=20
CT_ERROR_RATE_CRIT_PERCENT=50
CT_P95_WARN_SECONDS=5
CT_P95_CRIT_SECONDS=10
CT_NOTIFICATIONS_ENABLED=true

# Redis 当前为预留配置，未启用时留空。
CT_REDIS_ADDR=
# Redis 密码，未启用时留空。
CT_REDIS_PASSWORD=

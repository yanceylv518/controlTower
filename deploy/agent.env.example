CT_AGENT_ID=REPLACE_WITH_AGENT_ID
CT_INSTANCE_ID=REPLACE_WITH_INSTANCE_ID
CT_SERVER_URL=https://control-tower.example.com
CT_AGENT_TOKEN=REPLACE_WITH_AGENT_TOKEN
CT_LOG_DSN=REPLACE_WITH_READONLY_LOG_DATABASE_DSN
CT_DATA_DIR=/var/lib/control-tower-agent
CT_LOG_POLL_INTERVAL_SECONDS=30
CT_LOG_BATCH_SIZE=1000
CT_LOG_QUERY_TIMEOUT_SECONDS=2
CT_REPORT_TIMEOUT_SECONDS=3
CT_MAX_LOCAL_BUFFER_EVENTS=5000
# full_debug is only needed if you also want the SERVER-side recent_errors rule;
# the agent-side DingTalk alert below works in every mode
CT_LOG_EVENT_MODE=aggregate_with_samples
CT_LOG_SAMPLE_LIMIT=50
CT_SLOW_LOG_THRESHOLD_SECONDS=10
CT_NEW_API_STATUS_URL=http://127.0.0.1:3000/api/status
CT_DOCKER_ENABLED=true
CT_AGENT_FAKE_EVENT=false
CT_AGENT_RUN_ONCE=false

# Nginx timed access log analytics. Empty disables it; missing files retry safely.
# Requires CT_SERVER_URL and therefore does not run in standalone mode.
CT_NGINX_ACCESS_LOG=
CT_NGINX_SLOW_RT_SECONDS=10





# Channel control is disabled by default. Keep this token on the Agent host only.
CT_NEW_API_CONTROL_ENABLED=false
CT_NEW_API_ADMIN_API_URL=http://127.0.0.1:3000
CT_NEW_API_ADMIN_USERNAME=REPLACE_WITH_NEW_API_ADMIN_USERNAME
CT_NEW_API_ADMIN_PASSWORD=REPLACE_WITH_NEW_API_ADMIN_PASSWORD
CT_NEW_API_ADMIN_ACCESS_TOKEN=REPLACE_WITH_NEW_API_ADMIN_ACCESS_TOKEN
CT_NEW_API_ADMIN_USER_ID=REPLACE_WITH_NEW_API_ADMIN_USER_ID

# Agent-side DingTalk error alert (see agent/README.md); with the webhook set,
# CT_SERVER_URL becomes optional (standalone alert-only mode).
CT_DINGTALK_WEBHOOK_URL=
CT_ALERT_ERROR_WINDOW=10
CT_ALERT_ERROR_THRESHOLD=3
